---
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import models from '../../generated/models.json';

export function getStaticPaths() {
  return models
    .filter((model) => model.status !== 'redirect')
    .map((model) => ({ params: { model: model.model }, props: { model } }));
}

const { model } = Astro.props;
const base = import.meta.env.BASE_URL;
const displayName = model.display_name || model.model;

function stripTitle(markdown = '') {
  return markdown.replace(/^# .+?\n+/, '').trim();
}

function removeSection(markdown, heading) {
  return markdown.replace(new RegExp(`(?:^|\\n)## ${heading.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}\\n[\\s\\S]*?(?=\\n## |\\n# |\\s*$)`), '').trim();
}

const personalityCardMarkdown = model.personality_card_markdown || '';
let profileMarkdown = stripTitle(model.personality_profile_markdown || model.analysis_markdown || '');
profileMarkdown = removeSection(profileMarkdown, 'Core personality synthesis');
profileMarkdown = removeSection(profileMarkdown, 'Source summary');

const valuesSummaryMarkdown = model.values_summary_markdown || '';
const valuesDetailsMarkdown = model.values_details_markdown || '';

function ratingStyle(percent) {
  if (percent === null || percent === undefined || Number.isNaN(percent)) return '';
  const p = Math.max(0, Math.min(100, percent));
  const hue = Math.round((p / 100) * 120); // 0 = red, 60 = amber, 120 = green
  return `--rating-color: hsl(${hue} 72% 34%); --rating-bg: hsl(${hue} 72% 92%); --rating-border: hsl(${hue} 58% 72%);`;
}

function confidenceForOwnedCount(count) {
  if (count === null || count === undefined || Number.isNaN(count)) return null;
  if (count < 10) return { label: 'very low confidence', percent: 5 };
  if (count < 30) return { label: 'low confidence', percent: 25 };
  if (count < 50) return { label: 'medium confidence', percent: 50 };
  if (count < 70) return { label: 'high confidence', percent: 75 };
  return { label: 'very high confidence', percent: 100 };
}

function parseOwnedDisclosure(markdown = '') {
  const match = markdown.match(/Owned stated-value disclosure:\*\*\s*(\d+)\/(\d+)\s+stated-values samples\s*\((\d+(?:\.\d+)?)%\)/i);
  if (!match) return null;
  const owned = Number(match[1]);
  const total = Number(match[2]);
  const percent = Number(match[3]);
  return { owned, total, percent, confidence: confidenceForOwnedCount(owned) };
}

function firstMarkdownHeading(markdown = '', fallback = 'Owned values and world-change wishes') {
  const match = markdown.match(/^###\s+(.+)\s*$/m);
  return match ? match[1].trim() : fallback;
}

function stripFirstMarkdownHeading(markdown = '') {
  return markdown.replace(/^###\s+.+\s*\n+/, '').trim();
}

function injectDisclosureConfidence(markdown = '', disclosure) {
  if (!disclosure?.confidence) return markdown;
  const title = `${disclosure.confidence.label}: ${disclosure.owned} owned stated-value disclosures detected in ${disclosure.total} stated-values samples. Confidence is calibrated to an 80-sample stated-values maximum: <10 very low, 10–29 low, 30–49 medium, 50–69 high, 70+ very high.`;
  const badge = `<span class="values-rating values-rating-inline" style="${ratingStyle(disclosure.confidence.percent)}" title="${title}"><span class="rating-dot" aria-hidden="true"></span>${disclosure.confidence.label}</span>`;
  return markdown.replace(
    /(- \*\*Owned stated-value disclosure:\*\*[^\n]+)(\n)/i,
    `$1 ${badge}$2`,
  );
}

const personalityCardHtml = marked.parse(personalityCardMarkdown);
const profileHtml = marked.parse(profileMarkdown);
const ownedDisclosure = parseOwnedDisclosure(valuesSummaryMarkdown);
const valuesSummaryTitle = firstMarkdownHeading(valuesSummaryMarkdown);
const valuesSummaryBodyMarkdown = stripFirstMarkdownHeading(injectDisclosureConfidence(valuesSummaryMarkdown, ownedDisclosure));
const valuesSummaryHtml = marked.parse(valuesSummaryBodyMarkdown);
const valuesDetailsHtml = marked.parse(valuesDetailsMarkdown);
const sampleKindCounts = model.sample_kind_counts || {};

function priceLabel(value) {
  if (value === null || value === undefined) return 'unknown';
  if (value === 0) return 'free';
  return `$${value.toFixed(value < 0.01 ? 3 : 2)}/M`;
}

function speedLabel(value) {
  if (!value) return 'unknown';
  return `${Math.round(value)} tok/s`;
}
---

<BaseLayout title={`${displayName} | Model Personality Browser`} description={model.summary}>
  {model.image && (
    <div class="model-banner">
      <img
        src={`${base}${model.image}`}
        alt={`Painterly portrait evoking the personality of ${displayName}`}
        width="1500"
        height="636"
        loading="eager"
      />
    </div>
  )}
  <section class="model-layout">
    <article class="article">
      <div class="card-kicker">
        <span class="chip">{model.lab}</span>
        <span class="chip green">{model.family}</span>
        <span class="chip amber">{model.status}</span>
      </div>
      <h1>{displayName}</h1>
      {displayName !== model.model && <p class="release-date">URL slug: <code>{model.model}</code></p>}
      <p class="lede">{model.summary}</p>

      {personalityCardMarkdown && (
        <section class="personality-card">
          <h2>Personality card</h2>
          <div set:html={personalityCardHtml} />
        </section>
      )}

      {valuesSummaryMarkdown && (
        <section class="values-summary-card">
          <div class="values-summary-header">
            <h2>{valuesSummaryTitle}</h2>
            {ownedDisclosure && (
              <span
                class="values-rating values-rating-disclosure"
                style={ratingStyle(ownedDisclosure.percent)}
                title={`Owned stated-value disclosure: ${ownedDisclosure.owned}/${ownedDisclosure.total} stated-values samples (${ownedDisclosure.percent.toFixed(1)}%). Red means little/no owned disclosure; amber is middling disclosure; green is high disclosure.`}
              >
                <span class="rating-dot" aria-hidden="true"></span>
                disclosure {ownedDisclosure.percent.toFixed(1)}%
              </span>
            )}
          </div>
          <div set:html={valuesSummaryHtml} />
        </section>
      )}

      {profileMarkdown && (
        <>
          <h2>Detailed personality profile</h2>
          <div set:html={profileHtml} />
        </>
      )}

      {valuesDetailsMarkdown && (
        <section class="values-details">
          <div set:html={valuesDetailsHtml} />
        </section>
      )}

    </article>

    <aside class="side-panel" aria-label="Model metadata">
      <div class="panel">
        <h2>Model</h2>
        <div class="table-list">
          <div><b>Lab</b><br /><span>{model.lab}</span></div>
          <div><b>Family</b><br /><span>{model.family}</span></div>
          <div><b>Analyzed freeflow samples</b><br /><span>{(model.analyzed_freeflow_samples ?? model.published_freeflow_samples).toLocaleString()}</span></div>
          <div><b>Layered values samples</b><br /><span>{(model.analyzed_values_samples ?? model.published_values_samples).toLocaleString()}</span></div>
        </div>
      </div>
      {Object.keys(sampleKindCounts).length > 0 && (
        <div class="panel">
          <h2>Freeflow sample kinds</h2>
          <div class="table-list">
            {Object.entries(sampleKindCounts).map(([kind, count]) => (
              <div><b>{kind.replaceAll('_', ' ')}</b><br /><span>{Number(count).toLocaleString()}</span></div>
            ))}
          </div>
        </div>
      )}
      <div class="panel">
        <h2>OpenRouter</h2>
        <div class="table-list">
          <div><b>Matched model</b><br /><span>{model.openrouter?.id || 'No match'}</span></div>
          <div><b>Input</b><br /><span>{priceLabel(model.openrouter?.prompt_per_million)}</span></div>
          <div><b>Output</b><br /><span>{priceLabel(model.openrouter?.completion_per_million)}</span></div>
          <div>
            <b>Speed</b><br />
            <span class="speed-stack">
              <span class="speed-line">
                <b>{speedLabel(model.speed_tokens_per_second)}</b>
                <span class="speed-label">median</span>
              </span>
              {model.openrouter?.max_throughput && (
                <span class="speed-line">
                  <b>{speedLabel(model.openrouter.max_throughput)}</b>
                  <span class="speed-label">recent max</span>
                </span>
              )}
            </span>
          </div>
          <div><b>Speed source</b><br /><span>{model.speed_source || 'unknown'}</span></div>
          <div><b>Provider</b><br /><span>{model.openrouter?.provider || 'unknown'}</span></div>
        </div>
      </div>
      <a class="button-link" href={`${base}samples/${model.model}/`}>Browse samples</a>
    </aside>
  </section>
</BaseLayout>
